# Copy to .env and fill in values for local Docker dev.

# ── Database ────────────────────────────────────────────────
# Inside docker-compose the host is the "postgres" service name.
# For running outside Docker (bare-metal), change host to localhost.
DATABASE_URL=postgresql+psycopg://market_ai:market_ai_pass@postgres:5432/market_ai

# Used by the postgres container to initialise the cluster.
POSTGRES_USER=market_ai
POSTGRES_PASSWORD=market_ai_pass
POSTGRES_DB=market_ai

# ── Mode ────────────────────────────────────────────────────
# PAPER or LIVE. Keep PAPER while developing.
MODE=PAPER

# Approve-mode default: true keeps the bot in "signal-only, no orders" until
# you flip it from the dashboard. Set to false only when you really mean it.
APPROVE_MODE_DEFAULT=true

# ── IBKR / IB Gateway ───────────────────────────────────────
# IB Gateway runs on the Windows host, NOT in a container.
# host.docker.internal is the DNS name Docker Desktop publishes for the host.
IB_HOST=host.docker.internal
IB_PORT=7497          # TWS paper=7497, TWS live=7496, Gateway paper=4002, Gateway live=4001
IB_CLIENT_ID=2        # trader uses a distinct clientId from any other IB session
