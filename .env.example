# Copy to .env and fill in values.
# DATABASE_URL overrides db.url / db.path in config.yaml.
DATABASE_URL=postgresql+psycopg://market_ai:market_ai_pass@localhost:5432/market_ai

# Used by docker-compose.yml
POSTGRES_USER=market_ai
POSTGRES_PASSWORD=market_ai_pass
POSTGRES_DB=market_ai

# Optional IBKR overrides
# IBKR_HOST=127.0.0.1
# IBKR_PORT=7497
# IBKR_CLIENT_ID=1
